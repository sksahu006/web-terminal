# Application Settings
APP_NAME=Virtual Workspace Platform
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin Settings (comma-separated GitHub usernames)
ADMIN_GITHUB_USERNAMES=admin-username

# Container Defaults
DEFAULT_CPU_LIMIT=1.0
DEFAULT_MEMORY_LIMIT=1024
DEFAULT_DISK_LIMIT=5
DEFAULT_MAX_RUNTIME=3600

# Docker Settings
DOCKER_NETWORK=workspace-network
WORKSPACE_IMAGE=workspace-dev:latest

# Traefik Settings
TRAEFIK_DOMAIN=localhost
